{
  "name": "remotelymatch",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "npm start --prefix backend",
    "lint": "npm run lint --prefix frontend 2>/dev/null || true",
    "test": "npm test --prefix backend",
    "push:render": "node scripts/push-local-data-to-render.js",
    "sync:mongo": "node scripts/sync-sqlite-to-mongo.js",
    "refresh:data": "node scripts/refresh-agent-data.js",
    "sync:render": "node scripts/refresh-agent-data.js && node scripts/push-local-data-to-render.js",
    "deploy:data": "node scripts/deploy-data-to-render.js",
    "mongo:up": "docker compose up -d mongo",
    "mongo:down": "docker compose down",
    "mongo:logs": "docker compose logs -f mongo"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
