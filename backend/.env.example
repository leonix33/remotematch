PORT=5100
NODE_ENV=development
MONGODB_URI=
# With Docker Compose Mongo (npm run mongo:up) — port 27018 if 27017 is taken:
# MONGODB_URI=mongodb://127.0.0.1:27018/remotelymatch
# Or use an existing local Mongo on 27017:
# MONGODB_URI=mongodb://127.0.0.1:27017/remotelymatch
JWT_ACCESS_SECRET=change_this_to_a_long_random_value
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
AGENT_HOME=/Users/user/job-event-agent
APP_NAME=remotelymatch
VITE_APP_NAME=remotelymatch
VITE_APP_URL=http://localhost:5173
RENDER_URL=https://remotematch.onrender.com

# Email — Resend (https://resend.com) for team invites & post-apply follow-up digests
RESEND_API_KEY=
# Sandbox: only delivers TO the email you signed up with on Resend
# EMAIL_FROM=remotelymatch <onboarding@resend.dev>
# Production: verify remotelymatch.app in Resend → Domains, then:
# EMAIL_FROM=remotelymatch <noreply@remotelymatch.app>
EMAIL_FROM=remotelymatch <onboarding@resend.dev>

# Open job market — all remote roles for any resume (set OPEN_JOB_MARKET=0 for legacy DevOps-only mode)
OPEN_JOB_MARKET=1

# Job ingestion sources (Node backend)
JOB_SOURCES_ENABLED=remoteok,remotive,himalayas,weworkremotely,greenhouse,lever,ashby,wellfound,dice,adzuna,indeed,workingnomads,devitjobs,aijobs,ycombinator,workatastartup
JOB_GREENHOUSE_BOARDS=anthropic,datadog,cloudflare,gitlab,mongodb,elastic,databricks,coinbase,fastly,reddit,grafanalabs,pinterest,okta,pagerduty,newrelic,twilio
JOB_LEVER_BOARDS=palantir,spotify
JOB_ASHBY_BOARDS=snowflake,openai,notion,ramp,linear,deel,supabase,cognition
DICE_SEARCH_KEYWORD=remote
# INDEED_RSS_URL=
# INDEED_SEARCH_QUERY=devops engineer remote
# Adzuna job API — https://developer.adzuna.com (register → API keys)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_WHAT=devops engineer remote
ADZUNA_WHERE=remote
ADZUNA_MAX_DAYS_OLD=7
USAJOBS_API_KEY=
USAJOBS_USER_EMAIL=
USAJOBS_KEYWORD=remote
