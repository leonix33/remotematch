PORT=5100
NODE_ENV=development
MONGODB_URI=
# With Docker Compose Mongo (npm run mongo:up) — port 27018 if 27017 is taken:
# MONGODB_URI=mongodb://127.0.0.1:27018/remotematch
# Or use an existing local Mongo on 27017:
# MONGODB_URI=mongodb://127.0.0.1:27017/remotematch
JWT_ACCESS_SECRET=change_this_to_a_long_random_value
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
OPENAI_API_KEY=
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
AGENT_HOME=/Users/user/job-event-agent
APP_NAME=RemoteMatch
VITE_APP_NAME=RemoteMatch
VITE_APP_URL=http://localhost:5173
RENDER_URL=https://remotematch.onrender.com

# Email invites (Resend) — https://resend.com
RESEND_API_KEY=
# Testing (only sends to your Resend account email):
# EMAIL_FROM=RemoteMatch <onboarding@resend.dev>
# Production (after verifying remotematch.app in Resend):
# EMAIL_FROM=RemoteMatch <noreply@remotematch.app>
EMAIL_FROM=RemoteMatch <onboarding@resend.dev>

# Job ingestion sources (Node backend)
JOB_SOURCES_ENABLED=remoteok,remotive,greenhouse,lever,ashby,wellfound,workatastartup,usajobs
JOB_GREENHOUSE_BOARDS=datadog,cloudflare,gitlab,mongodb,elastic,databricks,coinbase,fastly,reddit,grafanalabs,pinterest,okta,pagerduty,newrelic,twilio
JOB_LEVER_BOARDS=palantir,spotify
JOB_ASHBY_BOARDS=openai,notion,ramp,linear,deel,supabase,cognition
USAJOBS_API_KEY=
USAJOBS_USER_EMAIL=
USAJOBS_KEYWORD=devops OR cloud OR kubernetes
